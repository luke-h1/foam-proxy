{
  "name": "@foam/authorizer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "esbuild --bundle --minify --keep-names --sourcemap --sources-content=false --target=node22 --platform=node --outfile=dist/index.js src/index.ts",
    "clean": "rm -rf ./dist",
    "lint:check": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "prettier:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "prettier:fix": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit --passWithNoTests",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/serverless": "^7.120.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/debug": "^4.1.12",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "babel-jest": "^30.2.0",
    "esbuild": "^0.27.3",
    "eslint": "10.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
