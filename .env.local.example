# Copy to .env.local (gitignored) and fill in. Loaded by `make run-local`.

# proxy
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Local fallback for /api/magic. Leave MAGIC_LINK_SSM_PARAM unset so it doesn't hit SSM.
MAGIC_LINK_BLOB=
MAGIC_LINK_API_KEY=

# authorizer
API_KEY=

# alarm-notifier (at least one channel required)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
